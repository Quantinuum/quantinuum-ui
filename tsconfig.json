/* Visit https://aka.ms/tsconfig to read more about this file */
{
  "include": ["**/*.ts", "**/*.tsx"],
  "compilerOptions": {
    "paths": {
      "shadcn/ui/*": ["./src/shadcn/ui/*"],
      "./": ["./*"],
    },
    "target": "es2016",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "module": "esnext",
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "emitDeclarationOnly": true
  }
}
